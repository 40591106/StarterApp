<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  x:Class="StarterApp.Views.CreateReviewPage"
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:vm="clr-namespace:StarterApp.ViewModels"
  xmlns:sys="clr-namespace:System;assembly=netstandard"
  Title="Leave a Review">
  <ContentPage.ToolbarItems>
    <ToolbarItem Text="Back"
                 Command="{Binding NavigateBackCommand}"/>
  </ContentPage.ToolbarItems>

  <ScrollView>
    <Grid Padding="20"
          RowSpacing="20"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
      <!-- Rating -->
      <Label Grid.Row="0"
             Text="Rating (1-5)"
             FontSize="16"
             FontAttributes="Bold"/>
      <StackLayout Grid.Row="1"
                   Orientation="Horizontal">
        <Slider Minimum="1"
                Maximum="5"
                Value="{Binding Rating}"
                HorizontalOptions="FillAndExpand"
                MinimumTrackColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
        <Label Text="{Binding Rating, StringFormat='{0:F0} ★'}"
               VerticalOptions="Center"
               FontSize="16"
               FontAttributes="Bold"
               WidthRequest="50"/>
      </StackLayout>

      <!-- Comment -->
      <Label Grid.Row="2"
             Text="Comment"
             FontSize="16"
             FontAttributes="Bold"/>
      <Editor Grid.Row="3"
              Text="{Binding Comment}"
              HeightRequest="100"/>

      <!-- Error Message -->
      <Label Grid.Row="4"
             Text="{Binding ErrorMessage}"
             IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
             TextColor="Red"
             HorizontalOptions="Center"/>

      <!-- Submit Button -->
      <Button Grid.Row="5"
              Text="Submit Review"
              Command="{Binding SubmitReviewCommand}"
              IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
              BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
              TextColor="White"
              HeightRequest="50"/>
    </Grid>
  </ScrollView>
</ContentPage>
