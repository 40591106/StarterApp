<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  x:Class="RentalApp.Views.ItemDetailPage"
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:vm="clr-namespace:RentalApp.ViewModels"
  x:DataType="vm:ItemDetailViewModel"
  Title="Item Details">
  <!-- Item detail page showing item information, actions, and reviews. -->
  <ScrollView>
    <Grid Padding="20"
          RowSpacing="15">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <ActivityIndicator
        Grid.Row="0"
        IsRunning="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        HorizontalOptions="Center"/>

      <StackLayout Grid.Row="1"
                   Spacing="15">
        <Label Text="{Binding ErrorMessage}"
               TextColor="Red"/>

        <Border
          BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
          Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
          StrokeThickness="1"
          Padding="20">
          <Border.StrokeShape>
            <RoundRectangle CornerRadius="12"/>
          </Border.StrokeShape>
          <StackLayout Spacing="10">
            <Label Text="{Binding Item.Title}"
                   FontSize="22"
                   FontAttributes="Bold"/>
            <Label Text="{Binding Item.Category}"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
            <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} per day'}"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
            <Label Text="{Binding Item.Description}"
                   FontSize="14"/>
            <StackLayout Orientation="Horizontal"
                         Spacing="5">
              <Label Text="{Binding Item.AverageRating, StringFormat='{0:F1} ★'}"
                     FontSize="14"
                     FontAttributes="Bold"
                     TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
              <Label Text="{Binding Item.TotalReviews, StringFormat='({0} reviews)'}"
                     FontSize="14"
                     TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
            </StackLayout>
            <StackLayout Orientation="Horizontal"
                         Spacing="10">
              <Label Text="Listed by"
                     FontSize="14"
                     TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                     VerticalOptions="Center"/>
              <Label Text="{Binding Item.OwnerName}"
                     FontSize="14"
                     FontAttributes="Bold"
                     TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                     VerticalOptions="Center">
                <Label.GestureRecognizers>
                  <TapGestureRecognizer Command="{Binding NavigateToOwnerProfileAsyncCommand}"/>
                </Label.GestureRecognizers>
              </Label>
            </StackLayout>
          </StackLayout>
        </Border>

        <!-- Edit item button -->
        <Button
          Text="Edit Item"
          Command="{Binding NavigateToEditAsyncCommand}"
          IsVisible="{Binding CanEdit}"
          BackgroundColor="{StaticResource Primary}"
          TextColor="White"
          CornerRadius="8"
          HeightRequest="50"/>

        <!-- Request rent button -->
        <Button
          Text="Request to Rent"
          Command="{Binding NavigateToRentAsyncCommand}"
          IsVisible="{Binding CanRent}"
          BackgroundColor="{StaticResource Primary}"
          TextColor="White"
          CornerRadius="8"
          HeightRequest="50"/>

        <!-- View reviews button -->
        <Button Text="View Reviews"
                Command="{Binding NavigateToReviewsAsyncCommand}"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray700}}"
                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                CornerRadius="8"
                HeightRequest="50"/>

        <!-- Back button -->
        <Button
          Text="Back"
          Command="{Binding NavigateBackAsyncCommand}"
          BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray700}}"
          TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
          CornerRadius="8"
          HeightRequest="50"/>
      </StackLayout>
    </Grid>
  </ScrollView>
</ContentPage>
