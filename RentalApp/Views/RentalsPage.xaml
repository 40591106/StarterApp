<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  x:Class="RentalApp.Views.RentalsPage"
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:vm="clr-namespace:RentalApp.ViewModels"
  Title="Rentals">
  <!-- Rentals page listing current rental requests and status. -->
  <ContentPage.ToolbarItems>
    <ToolbarItem Text="Refresh"
                 Command="{Binding LoadRentalsCommand}"/>
  </ContentPage.ToolbarItems>

  <Grid RowDefinitions="Auto,Auto,*"
        Padding="20"
        RowSpacing="10">
    <!-- Tab Toggle -->
    <Grid Grid.Row="0"
          ColumnDefinitions="*,*">
      <!-- Incoming tab button -->
      <Button
        Grid.Column="0"
        Text="Incoming"
        Command="{Binding ShowIncomingTabCommand}"
        BackgroundColor="{Binding IncomingTabColor}"
        TextColor="White"/>
      <!-- Outgoing tab button -->
      <Button
        Grid.Column="1"
        Text="Outgoing"
        Command="{Binding ShowOutgoingTabCommand}"
        BackgroundColor="{Binding OutgoingTabColor}"
        TextColor="White"/>
    </Grid>

    <!-- Loading / Error -->
    <StackLayout Grid.Row="1">
      <ActivityIndicator
        IsRunning="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        HorizontalOptions="Center"/>
      <Label
        Text="{Binding ErrorMessage}"
        IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
        TextColor="Red"
        HorizontalOptions="Center"/>
    </StackLayout>

    <!-- Incoming List -->
    <CollectionView
      Grid.Row="2"
      ItemsSource="{Binding IncomingRentals}"
      IsVisible="{Binding ShowIncoming}">
      <CollectionView.EmptyView>
        <Label
          Text="No incoming rental requests."
          HorizontalOptions="Center"
          VerticalOptions="Center"
          TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
      </CollectionView.EmptyView>
      <CollectionView.ItemTemplate>
        <DataTemplate>
          <Border
            Margin="0,5"
            Padding="15"
            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
            StrokeThickness="1">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <StackLayout Spacing="5">
              <Label Text="{Binding ItemTitle}"
                     FontSize="16"
                     FontAttributes="Bold"/>
              <Label Text="{Binding BorrowerName, StringFormat='From: {0}'}"
                     FontSize="14"/>
              <Label
                Text="{Binding TotalPrice, StringFormat='Total: £{0:F2}'}"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
              <Grid ColumnDefinitions="*,Auto">
                <Label
                  Grid.Column="0"
                  Text="{Binding StartDate, StringFormat='{0:dd MMM yyyy}'}"
                  FontSize="12"
                  TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                <Label
                  Grid.Column="1"
                  Text="{Binding Status}"
                  FontSize="12"
                  FontAttributes="Bold"/>
              </Grid>
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10"
                    IsVisible="{Binding IsPending}">
                <!-- Approve rental button -->
                <Button
                  Grid.Column="0"
                  Text="Approve"
                  Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=ApproveRentalCommand}"
                  CommandParameter="{Binding}"
                  BackgroundColor="#54C054"
                  TextColor="White"/>
                <!-- Reject rental button -->
                <Button
                  Grid.Column="1"
                  Text="Reject"
                  Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=RejectRentalCommand}"
                  CommandParameter="{Binding}"
                  BackgroundColor="#EE3737"
                  TextColor="White"/>
              </Grid>

              <!-- Mark out for rent button -->
              <Button Text="Mark as Out for Rent"
                      IsVisible="{Binding IsApprovedAndStarted}"
                      Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=MarkOutForRentCommand}"
                      CommandParameter="{Binding}"
                      BackgroundColor="#5C6BC0"
                      TextColor="White"/>

              <!-- Mark completed button -->
              <Button
                Text="Mark as Completed"
                IsVisible="{Binding IsReturned}"
                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=CompleteRentalCommand}"
                CommandParameter="{Binding}"
                BackgroundColor="#54C054"
                TextColor="White"/>


            </StackLayout>
          </Border>
        </DataTemplate>
      </CollectionView.ItemTemplate>
    </CollectionView>

    <!-- Outgoing List -->
    <CollectionView
      Grid.Row="2"
      ItemsSource="{Binding OutgoingRentals}"
      IsVisible="{Binding ShowOutgoing}">
      <CollectionView.EmptyView>
        <Label
          Text="No outgoing rental requests."
          HorizontalOptions="Center"
          VerticalOptions="Center"
          TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
      </CollectionView.EmptyView>
      <CollectionView.ItemTemplate>
        <DataTemplate>
          <Border
            Margin="0,5"
            Padding="15"
            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
            StrokeThickness="1">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <StackLayout Spacing="5">
              <Label Text="{Binding ItemTitle}"
                     FontSize="16"
                     FontAttributes="Bold"/>
              <Label Text="{Binding OwnerName, StringFormat='Owner: {0}'}"
                     FontSize="14"/>
              <Label Text="{Binding TotalPrice, StringFormat='Total: £{0:F2}'}"
                     FontSize="14"
                     FontAttributes="Bold"
                     TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
              <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding StartDate, StringFormat='{0:dd MMM yyyy}'}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                <Label Grid.Column="1"
                       Text="{Binding Status}"
                       FontSize="12"
                       FontAttributes="Bold"/>
              </Grid>
              <Label Text="⚠️ Overdue!"
                     IsVisible="{Binding IsOverdue}"
                     TextColor="Red"
                     FontAttributes="Bold"
                     FontSize="14"/>
              <!-- Mark returned button -->
              <Button Text="Mark as Returned"
                      IsVisible="{Binding CanReturn}"
                      Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=ReturnRentalCommand}"
                      CommandParameter="{Binding}"
                      BackgroundColor="#54C054"
                      TextColor="White"/>
              <!-- Leave review button -->
              <Button Text="Leave Review"
                      IsVisible="{Binding IsCompleted}"
                      Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=LeaveReviewCommand}"
                      CommandParameter="{Binding}"
                      BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                      TextColor="White"/>
            </StackLayout>
          </Border>
        </DataTemplate>
      </CollectionView.ItemTemplate>
    </CollectionView>
  </Grid>
</ContentPage>
